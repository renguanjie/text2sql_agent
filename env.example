# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=text2sql_db

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j@123
NEO4J_DATABASE=neo4j

# LLM 配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=

# 检索配置
RETRIEVAL_TOP_K=5
BM25_K1=1.5
BM25_B=0.75

# SQL 配置
SQL_DIALECT=mysql
SQL_MAX_LENGTH=2000
SQL_VALIDATION_ENABLED=true

# 日志配置
LOG_LEVEL=INFO
